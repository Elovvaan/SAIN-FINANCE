# SAIN Finance sandbox environment variables
#
# Keep this file limited to safe placeholder values. Never commit real secrets.

# Optional public origin used by future integrations, canonical links, or deployment docs.
NEXT_PUBLIC_APP_URL=https://your-sain-finance-railway-domain.example

# Required only for the one-time creation of the first INSTITUTION_ADMIN authority.
# Set a long random secret in Railway, use it once through the authority bootstrap operation,
# then rotate or remove it after the first administrator exists.
SAIN_BOOTSTRAP_TOKEN=replace-with-a-long-random-secret
