# SAIN Finance environment variables
#
# Keep this file limited to safe placeholder values. Never commit real secrets.

# Optional public origin used by integrations, canonical links, or deployment documentation.
NEXT_PUBLIC_APP_URL=https://your-sain-finance-railway-domain.example

# Required PostgreSQL connection used by the Filing Office repository and migration runner.
DATABASE_URL=postgresql://user:password@host:5432/database

# Railway PostgreSQL normally requires TLS. Set false only for a trusted local database.
SAIN_DATABASE_SSL=true
SAIN_DATABASE_POOL_MAX=10
SAIN_DATABASE_IDLE_TIMEOUT_MS=30000
SAIN_DATABASE_CONNECTION_TIMEOUT_MS=10000

# Canonical institution key used by the Filing Office database repository.
SAIN_INSTITUTION_KEY=sain-finance

# Initial state creation is disabled unless this is explicitly true.
# Use only when deliberately bootstrapping a new empty database.
SAIN_ALLOW_INITIAL_STATE=false

# JSON persistence is an explicit local-development option and is rejected in production.
# SAIN_FILING_OFFICE_REPOSITORY=json

# Required only for the one-time creation of the first INSTITUTION_ADMIN authority.
# Set a long random secret in Railway, use it once through the authority bootstrap operation,
# then rotate or remove it after the first administrator exists.
SAIN_BOOTSTRAP_TOKEN=replace-with-a-long-random-secret

# Transitional operator login credentials until Phase 3 connects authentication to database users.
SAIN_ADMIN_EMAIL=operator@example.com
SAIN_ADMIN_PASSWORD=replace-with-a-password-of-at-least-12-characters

# HMAC secret used to sign HttpOnly operator sessions. Use at least 32 random characters.
SAIN_SESSION_SECRET=replace-with-at-least-32-random-characters
